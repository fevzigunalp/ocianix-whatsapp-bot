# ──────────────────────────────────────────────────────────────
# WhatsApp AI Platform — Environment template
# Copy to .env and fill every value before running `npm run build`.
# Do NOT commit real secrets. All values listed here are REQUIRED
# in production unless marked "optional".
# ──────────────────────────────────────────────────────────────

# === Database (pgvector-enabled) ===
DATABASE_URL=postgresql://wabot:CHANGE_ME@postgres:5432/wabot_platform

# === Auth / NextAuth v5 ===
# Generate with: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME
# Public canonical URL of the Next.js app. Must be HTTPS in production.
AUTH_URL=https://bot.ocianix.com
NEXTAUTH_URL=https://bot.ocianix.com

# === Redis ===
REDIS_URL=redis://redis:6379

# === MinIO (media storage) ===
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=wabot_minio
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=wabot-media

# === Evolution API (WhatsApp gateway) ===
# Server-to-server URL the Next app uses to talk to Evolution
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=CHANGE_ME

# === n8n (optional) ===
N8N_URL=
N8N_API_KEY=

# === AI providers ===
ANTHROPIC_API_KEY=sk-ant-...
# Optional — enables pgvector semantic retrieval. Without it the
# system falls back to text search and still works.
OPENAI_API_KEY=

# === App URLs ===
# Public canonical URL clients hit (used in emails, links, UI)
NEXT_PUBLIC_APP_URL=https://bot.ocianix.com
# Public URL Evolution API uses to POST webhooks to this app. Usually
# identical to NEXT_PUBLIC_APP_URL, but can be overridden if the
# webhook path is proxied through a different subdomain.
PUBLIC_WEBHOOK_URL=https://bot.ocianix.com

# === Runtime ===
NODE_ENV=production
PORT=3001

# === docker-compose.prod.yml secrets ===
# These are consumed by the prod compose override. Missing values
# cause docker compose up to fail fast (`:?` guards).
POSTGRES_USER=wabot
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=wabot_platform
REDIS_PASSWORD=CHANGE_ME
MINIO_ROOT_USER=wabot_minio
MINIO_ROOT_PASSWORD=CHANGE_ME

# n8n (optional — only if you run the n8n service)
N8N_USER=admin
N8N_PASSWORD=CHANGE_ME
N8N_PUBLIC_URL=https://n8n.ocianix.com
