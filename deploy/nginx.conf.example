# Canonical Nginx vhost for the WhatsApp AI Platform.
# Install:
#   sudo cp deploy/nginx.conf.example /etc/nginx/sites-available/wabot
#   sudo ln -s /etc/nginx/sites-available/wabot /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#   sudo certbot --nginx -d bot.ocianix.com
#
# Replace bot.ocianix.com with your real host.

upstream wabot_app {
    server 127.0.0.1:3001;
    keepalive 32;
}

# HTTP → HTTPS redirect
server {
    listen 80;
    listen [::]:80;
    server_name bot.ocianix.com;
    return 301 https://$host$request_uri;
}

# Main app
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name bot.ocianix.com;

    # TLS — filled in by certbot
    # ssl_certificate     /etc/letsencrypt/live/bot.ocianix.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/bot.ocianix.com/privkey.pem;

    client_max_body_size 20m;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Real-IP $remote_addr;

    # SSE stream — buffering MUST be off, timeout MUST be long
    location /api/sse {
        proxy_pass http://wabot_app;
        proxy_set_header Connection '';
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 1h;
        chunked_transfer_encoding on;
    }

    # Webhook from Evolution — keep short timeouts, allow body
    location /api/webhook/ {
        proxy_pass http://wabot_app;
        proxy_read_timeout 30s;
    }

    # Everything else
    location / {
        proxy_pass http://wabot_app;
        proxy_read_timeout 60s;
    }
}
